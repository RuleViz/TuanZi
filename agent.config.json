{
  "routing": {
    "enableDirectMode": true,
    "directIntentPatterns": ["介绍", "解释", "是什么", "谁是", "为什么", "how", "what", "who", "why"]
  },
  "policy": {
    "default": "allow",
    "tools": {
      "bash": "ask",
      "write": "ask",
      "edit": "ask",
      "delete_file": "ask"
    },
    "commandRules": {
      "deny": [
        "/^rm -rf\\b/i",
        "/^format\\b/i",
        "/^mkfs\\b/i",
        "/^shutdown\\b/i",
        "git reset --hard"
      ],
      "allow": ["npm test", "npm run build", "echo", "git status"]
    }
  },
  "webSearch": {
    "enabled": true,
    "provider": "mcp",
    "maxUsesPerTask": 2,
    "maxResultsPerUse": 5,
    "maxCharsPerPage": 20000,
    "cacheTtlMs": 600000
  },
  "toolLoop": {
    "searchMaxTurns": 12,
    "coderMaxTurns": 20,
    "noProgressRepeatTurns": 2
  },
  "mcp": {
    "enabled": false,
    "command": "",
    "args": [],
    "env": {},
    "tools": {
      "webSearch": "web_search",
      "fetchUrl": "fetch_url"
    },
    "startupTimeoutMs": 15000,
    "requestTimeoutMs": 30000
  }
}
